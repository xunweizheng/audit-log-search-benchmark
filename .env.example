# ============================================================================
# Database connection
# ============================================================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_DATABASE=ts_polaris_dev

# ============================================================================
# Source table & sibling-table naming
# ============================================================================
# Read-only source. Sibling bench tables will be created from this.
SOURCE_TABLE=audit_logs

# Sibling tables will be named: <prefix>v1, <prefix>v2, ... <prefix>v5
BENCH_TABLE_PREFIX=audit_logs_bench_

# ============================================================================
# Benchmark parameters
# ============================================================================
# How many times each query is repeated to compute P50/P95/P99
ITERATIONS=200

# Warmup runs are executed before measurement and their times are discarded.
# This lets the InnoDB buffer pool load relevant pages into memory so the
# first measured run is not unfairly slow.
WARMUP=5

# Leave empty to auto-pick the tenant with the most rows.
SAMPLE_TENANT=

# How many inserts the write benchmark should do per scheme
WRITE_ITERATIONS=2000

# Rows per multi-row INSERT statement in the write benchmark.
# Larger values amortize network round-trip cost so the measurement
# reflects MySQL's true per-scheme write penalty (especially v5 FULLTEXT).
# Set to 1 to reproduce the legacy per-row-INSERT behavior.
WRITE_BATCH_SIZE=50

# ============================================================================
# JSON paths used by scheme v3 (path extract) and v4 (generated column + index)
# Comma-separated. Each must be a valid MySQL JSON path expression.
# ============================================================================
JSON_PATHS=$.id,$.orderId,$.companyId

# ============================================================================
# Keywords used by scheme v1 (LIKE), v2 (JSON_SEARCH), v5 (FULLTEXT)
#
# Leave empty (recommended) to let the script auto-sample keywords from
# real data in the source table. The auto-sampler picks:
#   - common  : up to 3 strings that appear frequently
#   - rare    : up to 3 strings that appear only once or twice
#   - missing : 3 random UUIDs (guaranteed zero hits)
#
# If you want to override, provide a JSON array, e.g.:
#   KEYWORDS_COMMON=["order","user"]
# ============================================================================
KEYWORDS_COMMON=
KEYWORDS_RARE=
KEYWORDS_MISSING=

# ============================================================================
# Behavior
# ============================================================================
# If true, sibling bench tables survive after the run, so subsequent
# benchmarks reuse them without paying the setup cost again.
# If false, teardown is called automatically after the run.
KEEP_BENCH_TABLES=true
